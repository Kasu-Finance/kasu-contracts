{
    "name": "kasu-contracts",
    "version": "1.0.0",
    "description": "kasu smart contracts",
    "main": "index.js",
    "scripts": {
        "node:local": "hardhat node --hostname 0.0.0.0",
        "test": "forge test",
        "test:coverage": "forge coverage --report lcov",
        "test:coverage:report": "forge coverage --report lcov && genhtml --ignore-errors category lcov.info -o report",
        "test:current": "forge test --mt test_fixedTermDeposit_equalRateDoesNotBurnShares -vv",
        "format:solidity": "forge fmt",
        "format:typescript": "prettier -w .",
        "build:solidity": "forge build",
        "scripts:deploy": "hardhat run --network localhost ./scripts/deploy.ts",
        "scripts:createTestLendingPools": "hardhat run --network localhost scripts/dev/lendingPools/createTestLendingPools.ts",
        "scripts:grantLendingPoolRole": "hardhat run --network base-sepolia scripts/lendingPools/grantLendingPoolRole.ts",
        "scripts:mockUsdc:mint": "hardhat run --network localhost scripts/dev/admin/mintMockUSDC.ts",
        "scripts:sendFunds": "hardhat run --network localhost scripts/dev/admin/sendFunds.ts",
        "scripts:testEventsLocal": "hardhat run --network localhost scripts/dev/testEventsLocal.ts",
        "scripts:requestDeposits": "hardhat run --network localhost scripts/dev/lendingPools/requestDeposits.ts",
        "scripts:clearingWorkFlow": "hardhat run --network localhost scripts/dev/clearing/runClearing.ts",
        "scripts:startClearingPeriod": "hardhat run --network localhost scripts/dev/clearing/startClearingPeriod.ts",
        "scripts:upgradeSingle": "hardhat run --network localhost scripts/upgradeSingle.ts",
        "scripts:doClearing": "hardhat run --network base-sepolia scripts/clearing/doClearing.ts",
        "scripts:repayOwedFunds": "hardhat run --network localhost scripts/lendingPools/repayOwedFunds.ts",
        "scripts:stopLendingPool": "hardhat run --network localhost scripts/lendingPools/stopLendingPool.ts",
        "scripts:updateDesiredDrawAmount": "hardhat run --network base-sepolia scripts/lendingPools/updateDesiredDrawAmount.ts",
        "scripts:createLendingPool": "hardhat run --network localhost scripts/lendingPools/createLendingPools.ts",
        "scripts:scenario1": "hardhat run --network localhost scripts/dev/scenarios/scenario1.ts",
        "scripts:smokeTest": "hardhat run --network localhost scripts/smokeTests/validateDeploymentComplete.ts",
        "scripts:smokeTest:base": "hardhat run --network base scripts/smokeTests/validateDeploymentComplete.ts",
        "scripts:smokeTest:plume": "hardhat run --network plume scripts/smokeTests/validateDeploymentComplete.ts",
        "scripts:smokeTest:roles": "hardhat run --network localhost scripts/smokeTests/validateRolesAndOwnership.ts",
        "scripts:smokeTest:pools": "hardhat run --network localhost scripts/smokeTests/validatePoolRoles.ts",
        "scripts:tenderly:createPool:base": "hardhat run --network base scripts/tenderly/simulateCreatePool.ts",
        "scripts:tenderly:createPool:plume": "hardhat run --network plume scripts/tenderly/simulateCreatePool.ts",
        "repl:kasu": "NETWORK_NAME=localhost ts-node scripts/dev/_repl/kasu_repl.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/solidant/kasu-contracts.git"
    },
    "keywords": [],
    "author": "",
    "license": "Proprietary",
    "bugs": {
        "url": "https://github.com/solidant/kasu-contracts/issues"
    },
    "homepage": "https://github.com/solidant/kasu-contracts#readme",
    "devDependencies": {
        "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
        "@nomicfoundation/hardhat-ethers": "^3.1.0",
        "@nomicfoundation/hardhat-foundry": "^1.1.1",
        "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
        "@nomicfoundation/hardhat-toolbox": "^4.0.0",
        "@nomicfoundation/hardhat-verify": "^2.0.8",
        "@openzeppelin/hardhat-upgrades": "^3.1.0",
        "@typechain/ethers-v6": "^0.5.0",
        "@typechain/hardhat": "^9.0.0",
        "@types/chai": "^4.2.0",
        "@types/mocha": "^10.0.0",
        "@types/node": "^20.11.0",
        "chai": "^4.2.0",
        "dotenv": "^16.3.1",
        "ethers": "^6.14.0",
        "hardhat": "^2.26.0",
        "hardhat-contract-sizer": "^2.10.0",
        "hardhat-gas-reporter": "^1.0.8",
        "picomatch": "^4.0.3",
        "solidity-coverage": "^0.8.1",
        "ts-node": "^10.9.2",
        "typechain": "^8.3.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@openzeppelin/contracts": "5.0.2",
        "@openzeppelin/contracts-upgradeable": "5.0.2"
    },
    "overrides": {
        "fdir": {
            "picomatch": "4.0.3"
        }
    }
}
