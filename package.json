{
    "name": "kasu-contracts",
    "version": "1.0.0",
    "description": "kasu smart contracts",
    "main": "index.js",
    "scripts": {
        "node:local": "hardhat node --hostname 0.0.0.0",
        "test": "forge test",
        "test:coverage": "forge coverage --report lcov",
        "test:coverage:report": "forge coverage --report lcov && genhtml lcov.info -o report",
        "test:current": "forge test --mt test_clearing_lendingPoolTwoTranches -vv",
        "format:solidity": "forge fmt",
        "format:typescript": "prettier -w .",
        "build:solidity": "forge build",
        "scripts:deploy:base-sepolia": "DEPLOYER_KEY= ADMIN_KEY= hardhat run --network base-sepolia ./scripts/deploy.ts",
        "scripts:deploy": "hardhat run --network localhost ./scripts/deploy.ts",
        "scripts:testEventsLocal": "hardhat run --network localhost ./scripts/testEventsLocal.ts",
        "scripts:clearingWorkFlow": "hardhat run --network localhost ./scripts/clearingWorkflow.ts",
        "scripts:checkProxyAdmin": "hardhat run --network localhost ./scripts/checkProxyAdmin.ts",
        "scripts:createTestLendingPools": "hardhat run --network localhost ./scripts/createTestLendingPools.ts",
        "scripts:createTestLendingPools:base:sepolia": "ADMIN_KEY= hardhat run --network base-sepolia ./scripts/createTestLendingPools.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/solidant/kasu-contracts.git"
    },
    "keywords": [],
    "author": "",
    "license": "Proprietary",
    "bugs": {
        "url": "https://github.com/solidant/kasu-contracts/issues"
    },
    "homepage": "https://github.com/solidant/kasu-contracts#readme",
    "devDependencies": {
        "@nomicfoundation/hardhat-ethers": "^3.0.5",
        "@nomicfoundation/hardhat-foundry": "^1.1.1",
        "@nomicfoundation/hardhat-toolbox": "^4.0.0",
        "@openzeppelin/hardhat-upgrades": "^3.1.0",
        "@types/node": "^20.11.0",
        "dotenv": "^16.3.1",
        "ethers": "^6.12.0",
        "hardhat": "^2.19.4"
    }
}
