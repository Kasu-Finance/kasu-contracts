{
    "name": "kasu-contracts",
    "version": "1.0.0",
    "description": "kasu smart contracts",
    "main": "index.js",
    "scripts": {
        "node:local": "hardhat node --no-deploy --hostname 0.0.0.0",
        "deploy:local": "hardhat --network localhost deploy --export-all deployments/localhost/export.json",
        "test": "forge test",
        "test:coverage": "forge coverage --report lcov",
        "format:solidity": "forge fmt",
        "format:typescript": "prettier -w .",
        "build:solidity": "forge build",
        "scripts:testEventsLocal": "hardhat run --network localhost ./scripts/testEventsLocal.ts",
        "scripts:lendingPoolWorkFlow": "hardhat run --network localhost ./scripts/lendingPoolWorkFlow.ts",
        "scripts:runClearing": "hardhat run --network localhost ./scripts/runClearing.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/solidant/kasu-contracts.git"
    },
    "keywords": [],
    "author": "",
    "license": "Proprietary",
    "bugs": {
        "url": "https://github.com/solidant/kasu-contracts/issues"
    },
    "homepage": "https://github.com/solidant/kasu-contracts#readme",
    "devDependencies": {
        "@nomicfoundation/hardhat-foundry": "^1.1.1",
        "@nomicfoundation/hardhat-toolbox": "^4.0.0",
        "@types/node": "^20.11.0",
        "ethers": "^6.9.2",
        "hardhat": "^2.19.4",
        "hardhat-deploy": "^0.11.45",
        "hardhat-deploy-ethers": "^0.4.1",
        "dotenv": "^16.3.1"
    }
}
