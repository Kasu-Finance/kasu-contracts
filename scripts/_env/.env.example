# =============================================================================
# Kasu Contracts Deployment Environment Variables
# =============================================================================
# Copy this file to .{network}.env (e.g., .base.env, .plume.env) and fill in values.
# The deployment script loads from: scripts/_env/.{network}.env
#
# IMPORTANT: Chain-specific settings (deployment mode, addresses, multisigs) are
# defined in scripts/_config/chains.ts - NOT here. Only add secrets and flags here.
#
# Usage:
#   npx hardhat --network base deploy        # Uses deploymentMode from chains.ts
#   npx hardhat --network plume deploy       # Uses deploymentMode from chains.ts
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Account Private Keys
# -----------------------------------------------------------------------------
# Deployer account - deploys contracts and becomes initial proxy admin
DEPLOYER_KEY=

# Admin account - receives KASU_ADMIN role, manages protocol
ADMIN_KEY=

# Optional: Test accounts (for local/testnet development)
# ALICE_KEY=
# BOB_KEY=

# -----------------------------------------------------------------------------
# DEPLOYMENT FLAGS
# -----------------------------------------------------------------------------
# NOTE: Deployment mode (full/lite) is chain-specific and set in chains.ts
#       Base: 'full' (with KSU token), other chains: 'lite' (without token)
#

# Deploy MockUSDC instead of using existing USDC (default: true for localhost)
# DEPLOY_MOCK_USDC=false

# Deploy SystemVariablesTestable with time manipulation (default: true for localhost)
# DEPLOY_SYSTEM_VARIABLES_TESTABLE=false

# Check and apply contract upgrades (default: true for localhost)
# DEPLOY_UPDATES=false

# Verify contracts on block explorer (default: true for non-localhost)
# VERIFY_SOURCE=true

# -----------------------------------------------------------------------------
# BLOCK EXPLORER API KEYS (for contract verification)
# -----------------------------------------------------------------------------
# Etherscan V2 Multichain API - single key for ALL supported chains
# Includes: Ethereum, Base, XDC, Arbitrum, Optimism, Polygon, and 100+ more
# See full list: https://docs.etherscan.io/supported-chains
# Get key at: https://etherscan.io/myapikey
# ETHERSCAN_API_KEY=

# Non-Etherscan explorers (separate keys required)
# Plume (phoenix-explorer.plumenetwork.xyz)
# PLUME_SCAN_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL: Chain Address Overrides
# -----------------------------------------------------------------------------
# These override defaults in scripts/_config/chains.ts
# Only use when deploying to a new/unknown chain not yet in chains.ts

# Wrapped native token (WETH, WXDC, etc.)
# WRAPPED_NATIVE_ADDRESS=0x...

# USDC or stablecoin address
# USDC_ADDRESS=0x...

# NexeraID signer (NexeraIDSignerManager contract address)
# NEXERA_ID_SIGNER=0x...

# -----------------------------------------------------------------------------
# OPTIONAL: Multisig Address Overrides
# -----------------------------------------------------------------------------
# NOTE: protocolFeeReceiver is also chain-specific and set in chains.ts
# Multisig addresses are defined in scripts/_config/chains.ts for each network.
# Only set these if you need to override the defaults for a specific deployment.
# KASU_MULTISIG=0x...
# POOL_MANAGER_MULTISIG=0x...
# POOL_ADMIN_MULTISIG=0x...
# PROTOCOL_FEE_CLAIMER=0x...

# -----------------------------------------------------------------------------
# SMOKE TEST VALIDATION
# -----------------------------------------------------------------------------
# Deployer address (read-only, for smoke test validation)
# Used by smoke tests to verify deployer doesn't retain admin privileges
# Can be set without DEPLOYER_KEY for read-only validation
# DEPLOYER_ADDRESS=0x...

# -----------------------------------------------------------------------------
# TENDERLY SIMULATIONS (optional)
# -----------------------------------------------------------------------------
# For transaction simulations without on-chain execution
# Sign up at: https://dashboard.tenderly.co
# Generate access key at: https://dashboard.tenderly.co/account/authorization
# TENDERLY_ACCESS_KEY=
# TENDERLY_ACCOUNT_ID=        # Your username or organization slug
# TENDERLY_PROJECT_SLUG=      # Your project slug
