# =============================================================================
# Kasu Contracts Deployment Environment Variables
# =============================================================================
# Copy this file to .{network}.env (e.g., .base.env, .plume.env) and fill in values.
# The deployment script loads from: scripts/_env/.{network}.env
#
# Usage:
#   npx hardhat --network base deploy
#   DEPLOYMENT_MODE=lite npx hardhat --network plume deploy
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Account Private Keys
# -----------------------------------------------------------------------------
# Deployer account - deploys contracts and becomes initial proxy admin
DEPLOYER_KEY=

# Admin account - receives KASU_ADMIN role, manages protocol
ADMIN_KEY=

# Optional: Test accounts (for local/testnet development)
# ALICE_KEY=
# BOB_KEY=

# -----------------------------------------------------------------------------
# DEPLOYMENT MODE
# -----------------------------------------------------------------------------
# "full" - Full deployment with KSU token, locking, and loyalty system
# "lite" - Lite deployment without token functionality (for chains without KSU)
DEPLOYMENT_MODE=full

# -----------------------------------------------------------------------------
# DEPLOYMENT FLAGS
# -----------------------------------------------------------------------------
# Deploy MockUSDC instead of using existing USDC (default: true for localhost)
# DEPLOY_MOCK_USDC=false

# Deploy SystemVariablesTestable with time manipulation (default: true for localhost)
# DEPLOY_SYSTEM_VARIABLES_TESTABLE=false

# Check and apply contract upgrades (default: true for localhost)
# DEPLOY_UPDATES=false

# Verify contracts on block explorer (default: true for non-localhost)
# VERIFY_SOURCE=true

# -----------------------------------------------------------------------------
# CHAIN-SPECIFIC ADDRESSES (Optional Overrides)
# -----------------------------------------------------------------------------
# These override the defaults in scripts/_config/chains.ts
# Only set if deploying to a new chain or need to override defaults

# Wrapped native token (WETH, WXDC, etc.)
# WRAPPED_NATIVE_ADDRESS=0x...

# USDC or stablecoin address (leave empty to deploy MockUSDC)
# USDC_ADDRESS=0x...

# NexeraID signer for KYC verification
# NEXERA_ID_SIGNER=0x29A75f22AC9A7303Abb86ce521Bb44C4C69028A0

# Protocol fee receiver (defaults to admin address if empty)
# PROTOCOL_FEE_RECEIVER=0x...

# -----------------------------------------------------------------------------
# BLOCK EXPLORER API KEYS (for contract verification)
# -----------------------------------------------------------------------------
# Base (Basescan)
# BASESCAN_API_KEY=

# XDC
# XDC_SCAN_API_KEY=

# -----------------------------------------------------------------------------
# RPC URLs (if not using defaults in hardhat.config.ts)
# -----------------------------------------------------------------------------
# XDC_RPC_URL=https://rpc.xdc.network
